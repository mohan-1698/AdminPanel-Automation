<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AdminPanel Suite" parallel="tests" thread-count="5">

    <listeners>
        <listener class-name="com.mock.hackathon.AdminPanel.listeners.TestListener"/>
    </listeners>

    <test name="Form Tests">
        <classes>
            <class name="com.mock.hackathon.AdminPanel.tests.FormTest"/>
        </classes>
    </test>

    <test name="Alert Tests">
        <classes>
            <class name="com.mock.hackathon.AdminPanel.tests.AlertTest"/>
        </classes>
    </test>

    <test name="Dynamic Tests">
        <classes>
            <class name="com.mock.hackathon.AdminPanel.tests.DynamicTest"/>
        </classes>
    </test>

</suite>